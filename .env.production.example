# Vidflow Studio — Production Environment Variables
# Copy this to .env.production and fill in your values

# ─── Database ───
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=vidflow_studio
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@postgres:5432/vidflow_studio

# ─── Redis & Celery ───
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ─── API Keys ───
OPENAI_API_KEY=sk-your-openai-key
DEEPSEEK_API_KEY=sk-your-deepseek-key

# ─── CORS ───
CORS_ORIGINS=https://your-domain.com,http://your-domain.com

# ─── Auth ───
JWT_SECRET_KEY=change-me-to-a-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ─── App ───
APP_NAME=Vidflow Studio
ENV=production
